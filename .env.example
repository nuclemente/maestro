# Maestro — variáveis de ambiente (template).
# Copie para `.env`. NUNCA versione `.env`.

# Runtime
MAESTRO_ENV=dev
MAESTRO_LOG_LEVEL=INFO
MAESTRO_LOG_FORMAT=text

# Server
MAESTRO_BACKEND_HOST=127.0.0.1
MAESTRO_BACKEND_PORT=8001
MAESTRO_FRONTEND_ORIGIN=http://localhost:5173

# Storage
MAESTRO_DB_PATH=data/maestro.db
# MAESTRO_DB_URL=sqlite:///absolute/path/to/maestro.db  # opcional — sobrescreve DB_PATH

# Claude CLI
MAESTRO_CLAUDE_CLI_PATH=/opt/homebrew/bin/claude
MAESTRO_CLAUDE_DEFAULT_TIMEOUT_S=120
MAESTRO_CLAUDE_DEFAULT_MAX_TURNS=5

# Skills/Agents discovery
MAESTRO_SKILLS_DIR=.claude/skills
MAESTRO_AGENTS_DIR=.claude/agents
