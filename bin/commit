#!/usr/bin/env zsh
# Uso: ./commit "mensagem do commit" [branch-de-destino]
#   - mensagem: obrigatória
#   - branch:   opcional; se informada, faz push para essa branch após o commit

set -euo pipefail

if [[ $# -lt 1 || -z "${1:-}" ]]; then
  print -u2 "Uso: $0 \"mensagem do commit\" [branch-de-destino]"
  exit 1
fi

local message="$1"
local target_branch="${2:-main}"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  print -u2 "Erro: diretório atual não é um repositório git."
  exit 1
fi

git add -A

if git diff --cached --quiet; then
  print -u2 "Nada para commitar."
  exit 0
fi

git commit -m "$message"

git push -u origin "HEAD:${target_branch}"
